# ==========================================
# ETF预测系统 Docker 环境变量配置
# ==========================================
# 复制此文件为 .env 并填写实际值

# ==================== 数据源配置 ====================
# Tushare Token（必需）
TUSHARE_TOKEN=your_tushare_token_here

# Tushare 代理 URL（可选）
TUSHARE_PROXY_URL=http://124.222.60.121:8020/

# Tinyshare Token（可选）
TINYSHARE_TOKEN=

# Minishare Token（可选）
MINISHARE_TOKEN=

# ==================== API 配置 ====================
# API 监听地址
API_HOST=0.0.0.0

# API 端口
API_PORT=8000

# ==================== 认证配置 ====================
# 管理员密钥
AUTH_KEY=admin123

# Session 密钥（生产环境请使用随机字符串）
SESSION_SECRET_KEY=change-this-in-production-use-random-key

# ==================== 调度配置 ====================
# 是否启用自动数据更新
UPDATE_SCHEDULE_ENABLED=true

# 数据更新时间
UPDATE_SCHEDULE_TIME=15:05

# ==================== 飞书通知配置 ====================
# 是否启用飞书通知
FEISHU_SCHEDULE_ENABLED=false

# 飞书 Webhook URL
FEISHU_WEBHOOK_URL=

# 飞书通知时间（逗号分隔）
FEISHU_NOTIFICATION_TIMES=09:40,10:40,11:40,13:40,14:40
