# ETF预测系统 - 环境变量配置示例

# ==================== 认证配置 ====================
# 会话密钥（必须随机且保密，用于加密session cookie）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your-random-session-secret-key-here

# 认证秘钥（访问系统的密码）
# 请设置一个强密码作为访问秘钥
AUTH_KEY=your-strong-access-key-here

# 飞书机器人配置
# ====================
# 支持配置多个机器人，每个机器人用 BOT_ 前缀 + 数字编号

# 默认机器人（BOT_1）
BOT_1_NAME=default
BOT_1_APP_ID=cli_a922558c12f95bc9
BOT_1_APP_SECRET=S835JryPfKQ9HcJpgER0ddWlNjwDqmzQ
BOT_1_CHAT_ID=oc_13b2ed371174bf3440c8763584341979

# 示例：添加第二个机器人
# BOT_2_NAME=backup
# BOT_2_APP_ID=your_second_app_id
# BOT_2_APP_SECRET=your_second_app_secret
# BOT_2_CHAT_ID=your_second_chat_id

# 示例：添加第三个机器人（用于特定用途）
# BOT_3_NAME=alerts
# BOT_3_APP_ID=your_third_app_id
# BOT_3_APP_SECRET=your_third_app_secret
# BOT_3_CHAT_ID=your_third_chat_id

# 默认使用的机器人名称
DEFAULT_BOT=default

# 单机器人简化配置（可选）
# 如果不想使用 BOT_1/BOT_2... 格式，可改用以下三项
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_CHAT_ID=
# FEISHU_BOT_NAME=default

# 定时任务配置（可选）
# SCHEDULER_TIMES=09:40,10:40,11:40,13:40,14:40
# SCHEDULER_BOT_NAME=default
# SCHEDULER_APP_ID=
# SCHEDULER_APP_SECRET=
# SCHEDULER_CHAT_ID=
# SCHEDULER_RUN_ON_STARTUP=true
# SCHEDULER_POLL_SECONDS=60
